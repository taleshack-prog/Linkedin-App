# App
BASE_URL=https://linkpost-api.up.railway.app
SECRET_KEY=            # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Railway
DATABASE_URL=postgresql+psycopg://user:pass@host:5432/railway
REDIS_URL=redis://default:pass@host:6379

# LinkedIn Developer Portal (produto "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect")
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_API_VERSION=202606

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Frontend (CORS) — adicionar a URL da Vercel em produção, separada por vírgula
FRONTEND_ORIGINS=http://localhost:5173

# Google Gemini (opcional — geração de imagem por IA; criar key em aistudio.google.com)
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# Provedor de imagem: "gemini" (default) ou "openai"
IMAGE_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_IMAGE_QUALITY=medium

# Google Sign-In (opcional — OAuth Client ID do Google Cloud Console)
GOOGLE_CLIENT_ID=

# Stripe (billing) — chaves em dashboard.stripe.com > Developers
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
FRONTEND_APP_URL=http://localhost:5173
